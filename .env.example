# Copy to .env and fill in. Without an API key the app runs with mock AI responses.

# --- AI provider (pick one) ---
# gemini = Google Gemini (recommended — free tier on Google AI Studio)
# openai = OpenAI
AI_PROVIDER=gemini

# Gemini — get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash

# OpenAI (only if AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TRANSCRIBE_MODEL=whisper-1

# --- Core ---
SECRET_KEY=dev-insecure-change-me
DEFAULT_LANG=th

# --- Environment / deployment ---
ENV=development
ALLOWED_HOSTS=*
SECURE_COOKIES=false
FORCE_HTTPS=false

# DATABASE_URL=postgresql+psycopg://mindmirror:mindmirror@db:5432/mindmirror
